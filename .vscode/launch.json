{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "renderDocuments: adsk Fusion",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/contrib/utilities/scripts/rendertest/renderDocuments.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONDONTWRITEBYTECODE": "1"
            },
            "args": [
                "--outputPath",
                "${workspaceFolder}/contrib/renders",
                "--geometryPath",
                "${workspaceFolder}/resources/Geometry/sphere.obj",
                "--radiancePath",
                "${workspaceFolder}/resources/Lights/san_giuseppe_bridge.hdr",
                "--irradiancePath",
                "${workspaceFolder}/resources/Lights/irradiance/san_giuseppe_bridge.hdr",
                "--size",
                "512",
                "${workspaceFolder}/contrib/adsk/resources/Materials/Examples/Fusion"
            ]
        },
        {
            "name": "extract_render_coverage: render_log.txt",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/contrib/utilities/scripts/rendertest/extract_render_coverage.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONDONTWRITEBYTECODE": "1"
            },
            "args": [
                "${workspaceFolder}/render_log.txt",
                "-o",
                "${workspaceFolder}/contrib/renders/legacy_coverage.txt"
            ]
        },
        {
            "name": "extract_render_coverage: compare manifests",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/contrib/utilities/scripts/rendertest/extract_render_coverage.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONDONTWRITEBYTECODE": "1"
            },
            "args": [
                "--manifest",
                "${workspaceFolder}/contrib/renders/legacy_coverage.txt",
                "--compare",
                "${workspaceFolder}/contrib/renders/pytest_coverage.txt"
            ]
        }
    ]
}
