{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Legacy Benchmark",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/contrib/utilities/scripts/rendertest/run_legacy_benchmark.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONDONTWRITEBYTECODE": "1"
            },
            "args": []
        },
        {
            "name": "Legacy Benchmark (Single Path)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/contrib/utilities/scripts/rendertest/run_legacy_benchmark.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONDONTWRITEBYTECODE": "1"
            },
            "args": [
                "${input:customPath}"
            ]
        }
    ],
    "inputs": [
        {
            "id": "customPath",
            "type": "promptString",
            "description": "Path to mtlx file or directory (e.g. contrib/adsk/resources/Materials)",
            "default": "contrib/adsk/resources/Materials"
        }
    ]
}
