{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "pytest - contrib/tests",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "contrib/tests",
                "-v",
                "-k", "Anodized_Blue"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {"PYTHONDONTWRITEBYTECODE": "1"}
        }
    ]
}
